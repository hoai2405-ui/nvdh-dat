generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id           Int     @id @default(autoincrement())
  fullName     String
  dob          String?
  cccd         String  @unique
  address      String? @db.Text
  className    String?
  cabinStatus  String? @default("chưa học")
  gvSoSan      String? @default("")
  xeSoSan      String? @default("")
  gvTuDong     String? @default("")
  xeTuDong     String? @default("")
  ngayDat      String? @default("")
  dot          String? @default("")
  ghiChu      String? @default("")
}

model Instructor {
  id    Int    @id @default(autoincrement())
  name  String @unique
  type  String
}

model Vehicle {
  id       Int    @id @default(autoincrement())
  plate    String @unique
  type     String
  donVi    String @default("An Ninh")
  gvMuon   String @default("")
  ngayMuon String @default("")
  ghiChu   String @default("")
  status   String @default("ranh")
}

model Box {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  status       String  @default("trong") // "trong" | "dang_muon"
  gvMuon       String?
  ngayMuon     String?
  gvTra        String?
  ngayTra      String?
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
  role     String @default("staff") // "admin" | "staff"

  settings Setting[]
}

model BoxHistory {
  id        Int    @id @default(autoincrement())
  plate     String
  donVi     String
  gvMuon    String
  ngayMuon  String @default("")
  ngayTra   String @default("")
  ghiChu    String @default("")
  action    String // "mượn" | "trả"
  createdAt String
}

model Setting {
  id     Int    @id @default(autoincrement())
  userId Int
  key    String
  value  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}